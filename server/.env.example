# Local Gemini proxy server environment
# Copy this file to server/.env and fill in your Gemini API key.

GEMINI_API_KEY=your_key_here
# Optional: change proxy port if needed
REZE_PROXY_PORT=5050

# On Android, localhost means the phone itself.
# Use your laptop IP address in the Expo app settings instead.
# Example: EXPO_PUBLIC_REZE_PROXY_URL=http://192.168.1.5:5050
